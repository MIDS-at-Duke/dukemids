{"version":3,"kind":"Notebook","sha256":"2a862efda9cf6ef57e43bb69c70e3411d1adc406fd3c8dfad2b5ffaab25f342f","slug":"buying-datascience-computer","location":"/professional_advice/buying_datascience_computer.ipynb","dependencies":[],"frontmatter":{"title":"Advice on Buying Computers for Data Science Students","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3.9.7 ('base')","language":"python"},"github":"https://github.com/MIDS-at-Duke/dukemids","numbering":{"title":{"offset":1}},"source_url":"https://github.com/MIDS-at-Duke/dukemids/blob/main/professional_advice/buying_datascience_computer.ipynb","edit_url":"https://github.com/MIDS-at-Duke/dukemids/edit/main/professional_advice/buying_datascience_computer.ipynb","exports":[{"format":"ipynb","filename":"buying_datascience_computer.ipynb","url":"/build/buying_datascience_c-ccf35c25b89567ed864effea4075fdf5.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"Questions to Ask Yourself","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"RqC6OC99kN"}],"identifier":"questions-to-ask-yourself","label":"Questions to Ask Yourself","html_id":"questions-to-ask-yourself","implicit":true,"key":"C7DrbQSl8y"},{"type":"paragraph","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"When thinking about getting a new computer, the three questions you need to ask yourself are:","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"rnLhkP4Zee"}],"key":"vo0xDlqJ9e"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":8,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"how budget-sensitive are you,","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"CpYL3hlaRB"}],"key":"Ok6dT0CyD2"}],"key":"XfYAZIZuPf"},{"type":"listItem","spread":true,"position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"how long does this need to be your main computer, and","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"muKKQZuHk8"}],"key":"gGztO4CKgt"}],"key":"Rlgb0cNYHc"},{"type":"listItem","spread":true,"position":{"start":{"line":10,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"do I actually need a new computer, or can I just upgrade my current computer?","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"inCpCh69B6"}],"key":"e2feTpbmWv"}],"key":"pQKJavYwoG"}],"key":"hcNQchhubg"},{"type":"paragraph","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"The “how long” question is important because many modern laptops—especially Apple laptops—have a lot of components that you can never upgrade. Ram and hard drives in Mac laptops, for example, are soldered in, so if a hard drive turns out to not be big enough, your only recourse is to buy a new laptop! Given that, you want to think about how long your laptop needs to work for you—if you think it’s gonna have to last you three years, you want to get a laptop with really good specs to help future-proof your purchase. But if you expect to get a new laptop when you finish your Master’s degree in two years, you don’t need to buy a computer that is nearly as future-proof.","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"PoQrGpPzUI"}],"key":"Kpbc0XcQcj"},{"type":"heading","depth":2,"position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"Key Specs","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"YsMkFSpJiK"}],"identifier":"key-specs","label":"Key Specs","html_id":"key-specs","implicit":true,"key":"uxJyTgC2nO"},{"type":"paragraph","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"I think the three things you want in a Data Science computer (in order of importance) are:","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"QOIKC8E5Ai"}],"key":"cWwKM0nz9H"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":18,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"Enough RAM:","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"XnueYc3jyT"}],"key":"rEj4jHNZtW"},{"type":"text","value":" I would argue that ","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"WnPf8pIr8J"},{"type":"strong","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"most","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"quUb0vYT5m"}],"key":"wHr4XQHyHg"},{"type":"text","value":" important feature of a laptop for a data scientist is RAM. You ","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"w6lF4rKQyD"},{"type":"emphasis","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"absolutely","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"oalj1YudsG"}],"key":"aTripJ7J1Z"},{"type":"text","value":" want at least 16GB of RAM. And honestly, your life will be a lot easier if you can get 32GB. And if you need a laptop that will last 3 years, I’d say you want 32GB or at least the ability to expand to 32GB later. ","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"mUwcOngfuV"},{"type":"strong","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"DO NOT BUY A LAPTOP WITH 8 GB RAM.","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"ZUbFWbFIQB"}],"key":"XkIC78eKPi"},{"type":"text","value":" I promise you’ll regret it instantly.","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"FT3zukXoZp"}],"key":"hLsvYiyDok"}],"key":"vO2XZysrvx"},{"type":"listItem","spread":true,"position":{"start":{"line":19,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"Storage:","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"l46nfog27R"}],"key":"KOrty894D2"},{"type":"text","value":" A relatively large, fast solid-state drive (an SSD, or another form of flash storage like an M.2 drive). I’d say 512GB is an absolute minimum, though personally, I wouldn’t go below 1TB. Note that external hard drives are poor substitutes for internal harddrives, so don’t get fooled into thinking “oh, it’s small, but I can always get an external drive!”","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"dCM5tnT9qj"}],"key":"beNU2HoB2E"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"If you only want this for a year or two, I’d say you probably want double the storage you currently use; if you’re gonna need this computer to last you a while I would say three times what you use now.","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"JnmVc5H6k8"}],"key":"bpe5y98cEj"}],"key":"AKZxWzkxru"}],"key":"kAr7O13iGp"}],"key":"iT8RWzxHc7"},{"type":"listItem","spread":true,"position":{"start":{"line":21,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"A reasonable processor:","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"GvIlf53wQV"}],"key":"zJvUBtiNgD"},{"type":"text","value":" At least an Intel i7, or an i9 if you can get it (for Windows), or an Apple M-Series chip. >= 6 cores I think. Note that I’m putting processors at the bottom of this list because, perhaps surprisingly, it’s probably the least critical component for a data scientist—that’s because single-core processor performance has not actually been ","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"SIt3hPglw7"},{"type":"link","url":"parallelism.ipynb","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"improving all that fast over the last decade or so","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"YyThgFs5Ca"}],"urlSource":"parallelism.ipynb","key":"iovTXJiUNA"},{"type":"text","value":", and most things you’ll do will be single core.","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"lQycBTPI9i"}],"key":"zzaQEZFiJ5"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":22,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":22,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Which M-series chip do you need? Honestly it doesn’t matter — they’re all a world better than Intel chips, and will be supported for a ","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"vK6FFraCIZ"},{"type":"emphasis","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"long","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"RFswxvoSrY"}],"key":"kkQAUE8prb"},{"type":"text","value":" time. So I wouldn’t worry too much about the differences between an M1/M1 Pro/M1 Ultra/M2/M3/etc. An M1 Pro or M1 Ultra will be better than an M1 or M2, but not by so much that you should stress it if you don’t have a lot of cash to burn.","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"SfY1Z2Wlys"}],"key":"J73s6R7Jx0"}],"key":"NXiKy6z0oP"}],"key":"ITUZM2wMNP"}],"key":"nAw3NrsXCm"}],"key":"gvLqABuuv5"},{"type":"paragraph","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"text","value":"GPUs are a tricky one. Until this year (2025) I would have said not to worry about GPUs — no GPU you will get in a laptop will be of any use for serious data science — if you need a GPU for training neural networks, you’ll need a dedicated GPU, probably from NVIDIA. And those are big things that generate too much heat to try and cram into a laptop. If you need one, you’ll use one in the cloud.","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"KZaKIVq9qr"}],"key":"QyM060TprN"},{"type":"paragraph","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"text","value":"But... having a ","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"huQfOZhNzr"},{"type":"emphasis","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"text","value":"reasonable","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"gaxuFUVZip"}],"key":"sIuNdZx76k"},{"type":"text","value":" GPU may allow you to run a large language model locally. This isn’t a “must,” but where I would have previously said “don’t even worry about the GPU,” I guess now I’d say that if a GPU upgrade is in your budget, you ","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"gZkizm7Hu1"},{"type":"emphasis","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"text","value":"might","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"SYhZSmNgm8"}],"key":"shjdPS2FXV"},{"type":"text","value":" get some benefit from it. Maybe.","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"UrLm00cx2p"}],"key":"W4q9DXP29i"},{"type":"paragraph","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"children":[{"type":"text","value":"On a Mac, this is also a ","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"yJMfoggUzP"},{"type":"emphasis","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"children":[{"type":"text","value":"potential","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"WAAJefMteK"}],"key":"wBmTkxYHPF"},{"type":"text","value":" reason to get a little extra RAM. On Macs, GPUs share the same memory as the processor (unlike most computers — this is what “unified memory” means), so more memory can be helpful if you want any local LLMs.","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"kPoZlkJbCD"}],"key":"MVdknFsKkh"},{"type":"paragraph","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"strong","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"text","value":"But don’t I need a super-computer for data science?!","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"unF2n8yyXd"}],"key":"ld4njlSZ16"}],"key":"AfPDqpmpxp"},{"type":"paragraph","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"text","value":"Nah. Don’t get me wrong, you want to be able to open any reasonably sized dataset on your computer and run code easily. But any time you’re doing something ","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"dvKfYNHi7E"},{"type":"emphasis","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"text","value":"really","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"zVsCctahNg"}],"key":"lb4KjnCjUk"},{"type":"text","value":" computationally intensive—like a massively parallelized computation and GPU-based training of deep learning networks—you’ll probably just do it on a cloud computer. You don’t want to have to turn to a cloud computer for simple class exercises, but just be aware that you always have that as a safety net for BIG jobs.","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"eJEllZuRqu"}],"key":"TlsEWvslPZ"}],"key":"sqJCRwudeu"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"Operating Systems","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"PWa0tFAZJk"}],"identifier":"operating-systems","label":"Operating Systems","html_id":"operating-systems","implicit":true,"key":"SbPSGm52aw"},{"type":"paragraph","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"Most MIDS students end up getting Macs, and I will admit that I prefer them too—that’s because in addition to just being fond of how their desktops integrate with their phones, all Apple computers run on an operating system that is very closely related to Linux (see ","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"LGiwpMQDDC"},{"type":"link","url":"../10_commandline/commandline_part1.ipynb","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"discussion here","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"MggqxchPsr"}],"urlSource":"../10_commandline/commandline_part1.ipynb","key":"dWncW9Nkjj"},{"type":"text","value":"). And since nearly all cloud computers run Linux, having a personal computer that has a linux-like operating system means that the skills you learn for working on the command line on your Mac will transfer to cloud computers. But like I said—I’m addicted to iMessages, so maybe that’s just Stockholm syndrome speaking. :-))","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"Ee6d6zdqgt"}],"key":"PH3WijVLEi"},{"type":"paragraph","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"Of course, Macs are also ","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"BFlegjASsa"},{"type":"emphasis","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"expensive","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"XRZO1tTl7f"}],"key":"GS8wasbtOi"},{"type":"text","value":", and while there are ways to try to get them cheaper (see notes below), you can definitely get more power from a Windows machine at the same price. Moreover, if you prefer getting a Windows machine for either price or personal preference reasons, you can actually run Linux ","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"fJZ0zhKBAh"},{"type":"emphasis","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"inside","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"aMQ9sqlfKv"}],"key":"Nea2vDBWSL"},{"type":"text","value":" Windows in a remarkably smooth matter with ","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"gdVpfjphsL"},{"type":"link","url":"https://docs.microsoft.com/en-us/windows/wsl/","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"WSL 2","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"u0NtlNLtb9"}],"urlSource":"https://docs.microsoft.com/en-us/windows/wsl/","key":"r4b791NRaf"},{"type":"text","value":". It will add some complexity to your life, but it’s workable!","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"rUbLFVcn5M"}],"key":"kuH801hqlT"},{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Finally, if you just want to get an actual Linux laptop, you can do that too! If you decide to go that route, I strongly suggest that you buy it from an established retailer who will make sure that everything is installed and set up when it arrives at your door like ","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"QHJdpDM2J1"},{"type":"link","url":"https://pop.system76.com/","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"System76","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"tjRij4WnLE"}],"urlSource":"https://pop.system76.com/","key":"GTKWdrm82u"},{"type":"text","value":". But be aware that managing Linux operating system is sure to come with some frustrations, so only do this if you enjoy mucking around and learning how operating systems really work.","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"q8NAexnas3"}],"key":"xvECgHcNqH"}],"key":"JIhK2tA3RZ"},{"type":"block","k