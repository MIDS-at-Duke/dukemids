"type":"text","value":"1. ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"elmGxHxGDZ"},{"type":"emphasis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Don’t","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"k8YFEKnoMj"}],"key":"dpcqBhJxUu"},{"type":"text","value":" Start with the LLM — Course Materials are Better","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"IZj37UbJrH"}],"identifier":"id-1-dont-start-with-the-llm-course-materials-are-better","label":"1. Don’t Start with the LLM — Course Materials are Better","html_id":"id-1-dont-start-with-the-llm-course-materials-are-better","implicit":true,"key":"gOrPYwust4"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Your instructor, your TAs, the materials you were assigned for a class, and your peers will almost always be better resources for you than LLMs in a reasonably well-designed class. That’s because they understand what you have been taught, where you are in your learning journey, and the learning goal of the assignment you’re working on. None of that information is available to an LLMs.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"u71mZixO4N"}],"key":"Jf1ZB512nm"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"As a result, we faculty see countless examples of students turning to LLMs when they hit a problem, only to have the LLM leading them ","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"nzTdnjTdWR"},{"type":"emphasis","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"way","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"CROAGg8hro"}],"key":"i64IYO1Z3Y"},{"type":"text","value":" off track. The answers LLMs give students may ","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"LK2o7xFXNO"},{"type":"emphasis","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"work","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"hQKvmx36rU"}],"key":"XSM2EGI2Ay"},{"type":"text","value":", but they’re often convoluted, unnecessarily complicated, and/or use packages or techniques that have not yet been introduced. And the consequence is students ","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"Mk0778fN8Q"},{"type":"emphasis","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"may","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"pDZ3BtBhRq"}],"key":"bsPdXmuU0i"},{"type":"text","value":" manage to solve the problem in front of them, but the often won’t learn what they’re supposed to learn.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"Ge9SVcBqmF"}],"key":"oaGqiuLidc"}],"key":"OPhOMfHAix"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"2. ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"geD8GqTZoh"},{"type":"emphasis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Do","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"fen69LkqXL"}],"key":"HUQAuHl4Fj"},{"type":"text","value":" Use LLMs for things that are","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Ep9v44DPzx"}],"identifier":"id-2-do-use-llms-for-things-that-are","label":"2. Do Use LLMs for things that are","html_id":"id-2-do-use-llms-for-things-that-are","implicit":true,"key":"YuaEpQoP9j"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":3,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"labor intensive to do,","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"HiapDFyMEt"}],"key":"NJaLF3kM7b"}],"key":"jXe0tjcGGQ"},{"type":"listItem","spread":true,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"you ","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"SVogMT8r2r"},{"type":"emphasis","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"could","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"TAqk2TyTCO"}],"key":"aSJLrQWz1Q"},{"type":"text","value":" do yourself, but which are","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"IaQlaolV0x"}],"key":"QuZb5ktCLI"}],"key":"n02083haF6"},{"type":"listItem","spread":true,"position":{"start":{"line":5,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"easy to verify have been done correctly.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"NA72uZPRnh"}],"key":"sPYmCYTPWu"}],"key":"rwr1VXvA51"}],"key":"vLgl6IQkOt"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Tasks that meet these three criteria are what I think of as being ","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"yIPia1vvQF"},{"type":"emphasis","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"right","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"cSwQji05G1"}],"key":"m3RWYHcWS4"},{"type":"text","value":" in the wheelhouse of AI. Using AI for things that are easy to do just dulls your skills, while using it for things that are annoying and time-consuming makes you more efficient. Moreover, asking for help with things you could do yourself (maybe with a little google help) means you’re asking for help with something you know even to check over. And finally, tasks that are labor-intensive to do but easily to validate mean you don’t have to overly rely on the AI to do something correctly.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"wWkkM8BG9s"}],"key":"CHJFv08wwD"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Examples of this type of task include:","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"tSSzpkpgOn"}],"key":"QEfV70i6Tp"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":11,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"paragraph","children":[{"type":"emphasis","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"Making refinements to matplotlib figures:","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"brlscl19tc"}],"key":"kNFn6P2YQa"},{"type":"text","value":" matplotlib has a thousand and one different methods and ways to tweak plots, so trying to find the exact right one to change a plot in a certain way (e.g., trying to “add text rotated ninety degrees between the figure and the legend”) can take you FOREVER. AI allows you to say what you want in plain English and leave the challenge of figuring out the exact incantation to the LLM. And of course, you can immediately look at the result to see if it worked! Of course, AI won’t always get things exactly right, so understanding at a conceptual level how a library like matplotlib works will allow you to tweak the solution provided by the LLM.","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"HSF90dfcJD"}],"key":"B50wgomr86"}],"key":"D5OI8PXrFW"},{"type":"listItem","spread":true,"position":{"start":{"line":12,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"paragraph","children":[{"type":"emphasis","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"Changing the way that files are named throughout a large project:","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"usanpd8uhN"}],"key":"tkcwBF4JGz"},{"type":"text","value":" often when we build big projects, we realize later in the project how it could be better organized. Recently, I had a project where I needed to change the structure of the names of files, such that any file in folders with a certain name needed to have that folder name put in the middle of the file name. I am confident I ","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"ZCoCYqKsKV"},{"type":"emphasis","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"could","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"djeOGRSlS0"}],"key":"FSlZNSJwUz"},{"type":"text","value":" use Python to iterate through all the folders in the project, use regular expressions to match the appropriate folders, then restructure the file names with regular expressions. But would it take me forever? Oh yes. So I asked an LLM — it wrote me a Python script I could skim, then I ran the file and was able to then browse through the files to check they looked right. Also, because my project was stored on github, I knew I could easily roll things back if I needed.","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"MWu7DG1Qp4"}],"key":"waA7jKxsDB"}],"key":"PpncJqmbZr"}],"key":"uhoZCaFQmj"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"If you’re asking AI to help with a task you ","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"yr2eNe0ok4"},{"type":"emphasis","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"could","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"NR1BAdE4eF"}],"key":"pOfHdErE6I"},{"type":"text","value":" do, that also implies it’s a task that you can also supervise.","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"caxY5aO6ok"}],"key":"BSpjVTsWLx"}],"key":"X8XCrJHCtr"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"3. ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"hiHb86RZ5P"},{"type":"emphasis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Don’t","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"J09mFQBP20"}],"key":"nocnuuZp4X"},{"type":"text","value":" use LLMs for things you don’t understand and can’t easily verify","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"pwczeKyO7o"}],"identifier":"id-3-dont-use-llms-for-things-you-dont-understand-and-cant-easily-verify","label":"3. Don’t use LLMs for things you don’t understand and can’t easily verify","html_id":"id-3-dont-use-llms-for-things-you-dont-understand-and-cant-easily-verify","implicit":true,"key":"mgJ6ZIxMBM"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"This may be the most important rule for data scientists: it’s easy to ask an AI to write you code to do a certain kind of analysis. But if you don’t understand that code, you can’t be sure it’s doing the thing you want it to do.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"SLXsFLPWRG"}],"key":"z1DLbeP951"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Why can’t you just check the answer? Because one of the things that makes data analysis different from software engineering is that you can’t easily validate the code generate the right answer since you’re analyzing the data to generate an answer no one has! When generating new knowledge, the only way to know if your code has given you the right answer is to have confidence in the code itself. Yes, you can (and should!) test your code against toy examples where you know the answer, but for the real data, the true answer is not known.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"Zrvl9csUxG"}],"key":"sUHPQeXR6x"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Thus, if you can’t check the work the LLM did, and you can’t verify its validity easily (as when formatting a plot or renaming files), you really shouldn’t be using LLM.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"ro7JLW9gLM"}],"key":"m6GsJfT5Jx"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Now, to be clear, that doesn’t mean you shouldn’t ever us an LLM for something you couldn’t do on your own ","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"mzS3w0Y7Cl"},{"type":"emphasis","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"without help","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"EkmwaA9oew"}],"key":"ASUfNfSoOb"},{"type":"text","value":". But if there are parts of the code the LLM generated that you aren’t familiar with, you should make sure you understand them before moving on. In other words, things that are a little beyond you, but close enough that you can understand it when you see it and maybe do a little thinking are good use cases for LLMs.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"Iixms08gI6"}],"key":"vD3laAnJTD"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"But don’t use an LLM to write a big block of code you really don’t get and use it if you can’t easily verify its correctness!!","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"WWzEYK3eNX"}],"key":"GicAm7jMNv"}],"key":"xgsgYllQel"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"4. ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"xFLFURDImm"},{"type":"emphasis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Don’t","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"D5DUC3mblk"}],"key":"w0eQYnPnC3"},{"type":"text","value":" let LLMs make suggestions in real time","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"syJ9lzbSRb"}],"identifier":"id-4-dont-let-llms-make-suggestions-in-real-time","label":"4. Don’t let LLMs make suggestions in real time","html_id":"id-4-dont-let-llms-make-suggestions-in-real-time","implicit":true,"key":"s7hPpXiC3P"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"As with so many technologies (looking at you social media), it’s important to also be sure YOU are in control of when and how AI is influencing your thinking.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"lXFfn7WFxp"}],"key":"XRUL8RFZ6H"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"For that reason, I much prefer chat-based LLM coding interfaces to tools that pop up suggests in read time in your browser. In particular, I use the Github Copilot chat interface when I use an LLM for coding. This is a chat window that opens in VS Code ","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"a2IM0jVPdS"},{"type":"emphasis","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"beside","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"sBQ2g4Q19v"}],"key":"IhZrDsOcrn"},{"type":"text","value":" my code to offer suggestions. The tool can directly modify my code if I ask it to, but it only acts if I ask it to act, and I can easily put it away.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"D7BJKiorSu"}],"key":"cR6nlOy5wj"},{"type":"image","url":"/build/copilot_chat_window-90d9d55ca13baa8ad3fe2a68151eac0e.png","alt":"copilot chat window","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"Y6iaB2Ww8j","urlSource":"images/copilot_chat_window.png"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"I’ve attached it to a keyboard shortcut so that I don’t have to leave it open to feel like it’s accessible. Instead, it’s almost never in view, and when I decide it would be helpful I invoke it, use it, and then close it.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"BN5oowMT7P"}],"key":"HsU8jxZLw3"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"Tools that offer code suggestions as you type (as greyed code suggestions), by contrast,\nare my absolute least favorite form of LLMs. The reason is that you can’t help but have your thought process influenced by those LLMs’ suggestions.","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"WuxVz4p5v9"}],"key":"MSOKU1f9mn"},{"type":"paragraph","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"“Sure,” you say, “I don’t have to accept the LLM suggestions.” That’s true, but even if you don’t ","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"awNlfagA0q"},{"type":"emphasis","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"accept","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"TMV6h8Qeqm"}],"key":"p3Ud0vYtim"},{"type":"text","value":" an LLM code-completion/recommendation, it is almost impossible to ignore text that pops up right in front of your cursor entirely. And as soon as you engage with that text mentally, it will start to influence how you think about a problem.","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"FZZeiM02c4"}],"key":"TymNDZrD0a"}],"key":"FYSXz4D078"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"5. ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"KHFhan4Dc1"},{"type":"emphasis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Do","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Gwqly5O4xY"}],"key":"Mm5dllpcaJ"},{"type":"text","value":" Us an LLM that can see your project","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"TRQHh8X0DO"}],"identifier":"id-5-do-us-an-llm-that-can-see-your-project","label":"5. Do Us an LLM that can see your project","html_id":"id-5-do-us-an-llm-that-can-see-your-project","implicit":true,"key":"rcLFtBlakz"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"One of the most important factors for getting good LLM results when coding is ensuring that the LLM can see what you’re working on. Context, in other words, is King.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"E4Kcg7ZmXz"}],"key":"q3NASKKTZs"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"So when you use an LLM, regardless of the UI, you should ask yourself, “Does the LLM have enough context for effective use?”","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"SJI6VudUjz"}],"key":"OfnOQv1KpD"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"That means that if you’re using a chat app running in your browser, make sure to upload the files that are relevant to your question.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"KvMKdOqzGA"}],"key":"nsSjeyzx2j"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Personally, I find the most straightforward way to give an LLM visibility into your work is to use Github Copilot Chat in VS Code. Using Copilot Chat means that the LLM will see all the files you have open or which are visible in your folders tab automatically. Moreover, it is model-agnostic, by which I mean it lets you pick from a range of different LLM models to work on the backend. (You can get Copilot Pro free with a ","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"JoR96W2VbT"},{"type":"link","url":"https://github.com/education/students","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Student Github account","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"OWpYEdCocD"}],"urlSource":"https://github.com/education/students","error":true,"key":"zLEEzzWjLc"},{"type":"text","value":", which gives you access to more models than you get for free).","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"d9aB4iEfN0"}],"key":"PyLLKKXDvp"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"If it’s helpful, I currently use Chat in ","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"qN0L6sZ4F3"},{"type":"inlineCode","value":"Agent","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"RFHIIPWxXf"},{"type":"text","value":" model (it will put code into your files in response to prompts and ask if you want to keep it) and Claude Sonnet 4.5:","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"Cd4kszuCvz"}],"key":"eEtmcWItly"},{"type":"image","url":"/build/copilot_chat_my_defa-28d006e8f5843c789e4c0a6ee30772c5.png","alt":"copilot chat choices","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"Yfo8XElVyZ","urlSource":"images/copilot_chat_my_defaults.png"}],"key":"HxMAJu1r2N"}],"key":"tUfBRdlsHv"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"chatGPT and You","url":"/llms","group":"Data Science Skills"},"next":{"title":"DCC stuff","url":"/dcc","group":"Data Science Skills"}}},"domain":"http://localhost:3004"}