text","value":"LLMs are very good at basic programming. As a result, they can do many of the assignments we are asking you to do.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"AvEVBkRUJd"}],"key":"g8b3p7gDoT"}],"key":"xbfUmIYNla"},{"type":"listItem","spread":true,"position":{"start":{"line":6,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"BUT","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"VaeiQSDt6p"}],"key":"u18Afu006a"},{"type":"text","value":": LLMs are ","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"sLOamUny1j"},{"type":"emphasis","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"not","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"PsBuH0BZqT"}],"key":"EAh3gI8tfO"},{"type":"text","value":" as good at the kind of work you will be doing professionally. At the professional level, LLMs require supervision, and you can only provide that supervision if you understand programming principles well enough to follow along. And you can’t learn programming principles without doing those early programming exercises yourself.","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"sA3UfkUZLK"}],"key":"wMIMT2rlt1"}],"key":"HuZHfGvy8w"}],"key":"CPRGGwi4RY"},{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"In other words, you have to know how to do the things that LLMs ","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"y3WS3qAz5M"},{"type":"emphasis","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"can","position":{"start":{"line":8,"column":1},"end":{"lin